
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
data/
server

# Stray beads export at repo root (canonical file lives in .beads/issues.jsonl)
/issues.jsonl

# Node is build-time only (make assets / the Dockerfile's Node stage); its
# fetched/bundled output is produced at build time, not committed to git.
node_modules/

# Built/fetched frontend assets — regenerated by `make assets` locally and by
# the Dockerfile's Node stage for images. A clean checkout has none of these, so
# a bare `go build` (without `make assets`) fails on the //go:embed pattern
# rather than silently embedding stale bytes.
/internal/api/assets/editor.js
/internal/api/assets/phosphor/
