
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
data/
server

# Stray beads export at repo root (canonical file lives in .beads/issues.jsonl)
/issues.jsonl

# Node is build-time only (make assets / the Dockerfile's Node stage); its
# fetched/bundled output is produced at build time, not committed to git.
node_modules/

# Built/fetched frontend assets (see scripts/build-assets.sh) — regenerated by
# `make assets` locally and by the Dockerfile's Node stage for images. Nothing
# here is committed, so a checkout that skips the build leaves it empty and a
# bare `go build` fails on the //go:embed pattern rather than embedding stale
# bytes.
/internal/api/assets/
