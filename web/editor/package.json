{
  "name": "artifact-editor",
  "private": true,
  "description": "CodeMirror 6 source-editor island, bundled by esbuild into internal/api/assets/editor.js (see `make assets`). Node is a build-time-only dependency.",
  "scripts": {
    "build": "esbuild editor.js --bundle --minify --format=iife --target=es2020 --outfile=../../internal/api/assets/editor.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.1",
    "codemirror": "^6.0.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.8"
  }
}
