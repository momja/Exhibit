{{/* Artifact detail (viewer) page. Data: detailPageData (gallery.go). */}}
{{define "detail"}}<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{.Title}} — Exhibit</title>
<link rel="stylesheet" href="/assets/phosphor/regular.css">
<style>:root{--brand-blue:{{.BrandBlue}};--brand-blue-hover:{{.BrandBlueHover}}}</style>
<link rel="stylesheet" href="/assets/gallery/detail.css">
</head>
<body>
<header>
  <a href="/">← Gallery</a>
  <h1>{{.Title}}</h1>
  <span style="font-size:12px;color:#888">{{.Created}}</span>
</header>
<div class="toolbar">
  <a href="{{.RenderOrigin}}/a/{{.ID}}" target="_blank">Open in new tab ↗</a>
  <span style="color:#ddd">|</span>
  <a href="/artifacts/{{.ID}}/edit"><i class="ph ph-pencil-simple"></i> Edit</a>
  <span style="color:#ddd">|</span>
  <a href="/agent?artifact={{.ID}}"><i class="ph ph-robot"></i> Modify with agent</a>{{if .SourceURL}}
  <span style="color:#ddd">|</span>
  <button onclick="refetchSource()">Update from source ↻</button>{{end}}
  <span style="color:#ddd">|</span>
  <span style="color:#888">Allowlist:</span>
  <span id="al-display">{{template "allowlistBadges" .Allowlist}}</span>
  <input id="al-input" type="text" placeholder="Add origin (https://example.com)" style="display:none">
  <button onclick="addOrigin()"><i class="ph ph-plus"></i> Add origin</button>
  <span style="color:#ddd">|</span>
  <span style="color:#888">Downloads:</span>
  <span id="dl-state"></span>
  <button id="dl-revoke" onclick="revokeDownloads()" style="display:none"><i class="ph ph-prohibit"></i> Revoke</button>
  <span style="color:#ddd">|</span>
  <span style="color:#888">Clipboard:</span>
  <span id="clip-state"></span>
  <button id="clip-revoke" onclick="revokeClipboard()" style="display:none"><i class="ph ph-prohibit"></i> Revoke</button>
  <span id="al-status" style="color:#888"></span>
</div>
<div class="panels">
  {{/* No allow="clipboard-*" delegation: the frame's opaque origin matches no
       Permissions-Policy allowlist, so the delegation was a no-op (av-hll6).
       Clipboard read/write is instead proxied through the host via the shim's
       capability bridge, gated by per-artifact first-use approval. Native
       keyboard paste (Ctrl/Cmd+V) is a browser event and works without it. */}}
  <iframe src="{{.RenderOrigin}}/a/{{.ID}}" sandbox="allow-scripts" loading="lazy"></iframe>
  <div class="panel"><pre>{{.Src}}</pre></div>
</div>

<div id="dl-modal" class="modal-overlay" hidden>
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="dl-title">
    <h2 id="dl-title">Allow downloads?</h2>
    <p><strong>{{.Title}}</strong> wants to download <code id="dl-filename"></code>.</p>
    <p>Allowing lets this artifact save files to your device from now on. You can revoke this at any time from the toolbar.</p>
    <div class="modal-actions">
      <span class="spacer"></span>
      <button type="button" class="btn btn-sec" id="dl-block">Block</button>
      <button type="button" class="btn" id="dl-allow"><i class="ph ph-download-simple"></i> Allow downloads</button>
    </div>
  </div>
</div>

<div id="clip-modal" class="modal-overlay" hidden>
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="clip-title">
    <h2 id="clip-title">Allow clipboard access?</h2>
    <p><strong>{{.Title}}</strong> wants to <span id="clip-direction">use</span> your clipboard.</p>
    <p>Allowing lets this artifact read and write your clipboard from now on. You can revoke this at any time from the toolbar.</p>
    <div class="modal-actions">
      <span class="spacer"></span>
      <button type="button" class="btn btn-sec" id="clip-block">Block</button>
      <button type="button" class="btn" id="clip-allow"><i class="ph ph-clipboard-text"></i> Allow clipboard</button>
    </div>
  </div>
</div>
<script>
const TOKEN = {{.Token}};
const ID = {{.ID}};
const SOURCE_URL = {{.SourceURL}};
let allowlist = {{.Allowlist}};
{{/* The booleans are emitted as literal template text rather than {{value}}
     interpolations: html/template's JS escaper pads identifiers with spaces,
     and a plain `= true;` keeps the bootstrap greppable. */ -}}
let downloadsApproved = {{if .DownloadsApproved}}true{{else}}false{{end}};
let clipboardApproved = {{if .ClipboardApproved}}true{{else}}false{{end}};
</script>
<script src="/assets/gallery/detail.js"></script>
</body>
</html>{{end}}
