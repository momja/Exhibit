{{/* Artifact edit page. Data: editPageData (gallery.go). */}}
{{define "edit"}}<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Edit: {{.Title}} — Exhibit</title>
<link rel="stylesheet" href="/assets/phosphor/regular.css">
<link rel="stylesheet" href="/assets/gallery/tokens.css">
<link rel="stylesheet" href="/assets/gallery/components.css">
<link rel="stylesheet" href="/assets/gallery/edit.css">
</head>
<body>
<header>
  <a href="/artifacts/{{.ID}}">← Back</a>
  <h1>Edit Artifact</h1>
</header>
<main>
<div class="edit-card">
  <h2>Edit</h2>

  <details class="details-panel" id="security-panel">
    <summary id="security-summary"><i class="ph ph-caret-right security-caret security-caret-closed" aria-hidden="true"></i><i class="ph ph-caret-down security-caret security-caret-open" aria-hidden="true"></i> <span id="security-summary-text"></span></summary>
    <div class="security-body">
      <div class="security-col">
        <h3 class="text-sm muted">Network allowlist</h3>
        <div id="allowlist-rows">
          {{range .Allowlist}}<div class="allowlist-row" data-origin="{{.}}">
            <code title="{{.}}">{{.}}</code>
            <button type="button" class="btn btn-sm btn-sec" data-action="remove">Remove</button>
          </div>{{end}}
        </div>
        {{if .Unapproved}}
        <h3 class="text-sm muted">Referenced, not approved</h3>
        <div id="unapproved-rows">
          {{range .Unapproved}}<div class="allowlist-row" data-origin="{{.}}">
            <code title="{{.}}">{{.}}</code>
            <button type="button" class="btn btn-sm" data-action="allow">Allow</button>
          </div>{{end}}
        </div>
        {{end}}
        <div class="row" style="margin-top:8px">
          <input type="text" id="al-add-input" class="field" placeholder="Add origin (https://example.com)">
          <button type="button" class="btn btn-sm" id="al-add-btn">Add</button>
        </div>
      </div>
      <div class="security-col">
        <h3 class="text-sm muted">Capabilities</h3>
        <label class="row">
          <span class="spacer">Downloads</span>
          <select id="dl-select" class="select">
            <option value="false">Ask first</option>
            <option value="true">Always allow</option>
          </select>
        </label>
        <label class="row">
          <span class="spacer">Clipboard</span>
          <select id="clip-select" class="select">
            <option value="false">Ask first</option>
            <option value="true">Always allow</option>
          </select>
        </label>
      </div>
    </div>
  </details>

  <input type="text" id="title" value="{{.Title}}" placeholder="Title">
  <textarea id="body">{{.Src}}</textarea>
  <div class="btn-row">
    <button class="btn" onclick="save()"><i class="ph ph-check"></i> Save</button>
    <a href="/artifacts/{{.ID}}"><button class="btn btn-sec" type="button"><i class="ph ph-x"></i> Cancel</button></a>
    <span id="status"></span>
    <span class="spacer"></span>
    <button class="btn btn-danger" type="button" onclick="deleteArtifact()"><i class="ph ph-trash"></i> Delete</button>
  </div>
  <div id="scan-result"></div>
</div>
</main>
<script src="/assets/editor.js"></script>
<script>
const TOKEN = {{.Token}};
const ID = {{.ID}};
let allowlist = {{.Allowlist}};
let unapproved = {{.Unapproved}};
{{/* Literal template text rather than {{value}} interpolation, matching the
     detail page bootstrap (av-p3gj): html/template's JS escaper pads
     booleans with spaces, and a plain `= true;` keeps this greppable. */ -}}
let downloadsApproved = {{if .DownloadsApproved}}true{{else}}false{{end}};
let clipboardApproved = {{if .ClipboardApproved}}true{{else}}false{{end}};
</script>
<script src="/assets/gallery/edit.js"></script>
</body>
</html>{{end}}
